# ===========================================
# NanoClaw Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# Claude Authentication (required)
# -------------------------------------------
# Use ONE of these authentication methods:

# Option 1: Claude subscription (recommended)
# Run `claude setup-token` to get your token
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: Anthropic API key (pay-per-use)
ANTHROPIC_API_KEY=

# -------------------------------------------
# Custom API Endpoints (optional)
# -------------------------------------------
# Override the default Anthropic API endpoint
# Example: https://api.z.ai/api/anthropic
ANTHROPIC_BASE_URL=

# Override default models (useful for custom endpoints)
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_SMALL_FAST_MODEL=

# -------------------------------------------
# Assistant Identity
# -------------------------------------------
# Name the assistant responds to (default: Andy)
ASSISTANT_NAME=Andy

# Set to 'true' if the assistant has its own phone number
# Used for WhatsApp channel to identify messages from the assistant
ASSISTANT_HAS_OWN_NUMBER=false

# -------------------------------------------
# Channel Configuration
# -------------------------------------------
# Enable channels by providing their credentials

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack (requires both tokens for Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# -------------------------------------------
# Container Settings
# -------------------------------------------
# Docker image for agent containers (default: nanoclaw-agent:latest)
CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout in milliseconds (default: 30 minutes)
CONTAINER_TIMEOUT=1800000

# Max concurrent containers (default: 5)
MAX_CONCURRENT_CONTAINERS=5

# Idle timeout before container cleanup (default: 30 minutes)
IDLE_TIMEOUT=1800000

# Max output size from container in bytes (default: 10MB)
CONTAINER_MAX_OUTPUT_SIZE=10485760

# -------------------------------------------
# Advanced Settings
# -------------------------------------------
# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Credential proxy port (default: 3001)
CREDENTIAL_PROXY_PORT=3001

# Timezone for scheduled tasks (uses system timezone by default)
TZ=
